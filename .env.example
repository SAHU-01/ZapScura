# ZapScura Environment Variables

# Starknet Network (devnet | sepolia | mainnet)
VITE_STARKNET_NETWORK=sepolia

# RPC URL (optional, defaults based on network)
# VITE_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia

# Contract Addresses (Starknet Sepolia — from StarkShield deployment)
VITE_VAULT_ADDRESS=
VITE_CDP_ADDRESS=
VITE_VERIFIER_ADDRESS=
VITE_SOLVENCY_ADDRESS=
VITE_PRICE_FEED_ADDRESS=
VITE_XYBTC_ADDRESS=

# DeepSeek AI API Key (server-side only for Vercel)
DEEPSEEK_API_KEY=

# DeepSeek API Key for local dev (exposed in browser — dev only!)
# VITE_DEEPSEEK_API_KEY=

# Deployer keys (for contract deployment scripts — NOT needed at runtime)
# DEPLOYER_PRIVATE_KEY=
# DEPLOYER_ACCOUNT_ADDRESS=

# Backend RPC URL (non-VITE, for deployment scripts)
# STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
